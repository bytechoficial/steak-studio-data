  "custom_css": "header .title-3d{font-weight:900!important;font-style:italic!important;text-transform:uppercase!important;color:#fff!important;text-shadow:0 1px 0 #0056b3,0 2px 0 #004494,0 5px 10px rgba(0,0,0,.5)!important;display:flex!important;align-items:center!important;gap:15px!important;position:relative!important}header .title-3d::before{content:''!important;width:24px!important;height:30px!important;background:#fbdf07!important;clip-path:polygon(50% 0%,100% 20%,80% 100%,20% 100%,0% 20%)!important;box-shadow:inset 0 0 10px #b48a00!important}header .title-3d::after{content:''!important;position:absolute!important;top:-20px;left:0;width:100%;height:150px;background:repeating-linear-gradient(90deg,rgba(0,168,89,0.2) 0,rgba(0,168,89,0.2) 2px,transparent 2px,transparent 20px,rgba(251,223,7,0.2) 20px,rgba(251,223,7,0.2) 22px,transparent 22px,transparent 40px)!important;animation:fitas-vazando 4s linear infinite!important;z-index:-1!important}@keyframes fitas-vazando{from{transform:translateY(-50px)}to{transform:translateY(0)}}header button{background:#00a859!important;border:2px solid #fbdf07!important;border-radius:10px!important;color:#fff!important;transition:transform 0.1s!important}header button:active{transform:scale(0.9)!important}aside .btn-pulse{background:linear-gradient(90deg,#00a859,#fbdf07)!important;color:#000!important;font-weight:900!important;font-style:italic!important;border-radius:12px!important;position:relative!important;overflow:hidden!important;border:none!important}aside .btn-pulse:active{animation:vibra-estadio 0.1s infinite!important}aside .btn-pulse::before{content:''!important;position:absolute!important;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent)!important;transition:0.5s}aside .btn-pulse:active::before{left:100%!important}@keyframes vibra-estadio{0%{transform:translate(1px,1px)}50%{transform:translate(-1px,-1px)}100%{transform:translate(0,0)}}#streak-input{background:#111!important;border:1px solid #fbdf07!important;color:#fff!important}.tab-btn.active{color:#00a859!important}.tab-btn.active::after{background:#fbdf07!important;height:4px!important}"
}