  "custom_css": "Body{background:linear-gradient(180deg,#006437 0%,#000 100%)!important}.title-3d{color:#ffdf00!important;text-shadow:0 1px 0 #002776,0 2px 0 #009b3a,0 3px 0 #fff,0 6px 1px rgba(255,255,255,.1),0 0 20px rgba(255,223,0,.4)!important}#streak-count{filter:drop-shadow(0 0 8px #ffdf00);animation:goal-pulse 1.5s infinite ease-in-out}@keyframes goal-pulse{0%,100%{transform:scale(1);filter:brightness(1)}50%{transform:scale(1.1);filter:brightness(1.3)}}.btn-pulse{background:linear-gradient(45deg,#009b3a,#ffdf00)!important;color:#002776!important;font-weight:900!important;border:none!important;box-shadow:0 0 15px rgba(0,155,58,.5)!important}.item-card{background:#fff!important;border-radius:15px!important}.selected-card{border-color:#002776!important;box-shadow:0 0 10px #002776}.sidebar{border-top:2px solid #ffdf00!important}.tab-btn.active{color:#009b3a!important}.tab-btn.active::after{background:#ffdf00!important}.v-control-btn{border-color:rgba(0,155,58,.3)!important}"
