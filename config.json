  "custom_css": "Body{background:radial-gradient(circle,#0a2d1a 0%,#000 100%)!important}.title-3d{color:#e63946!important;text-shadow:0 1px 0 #b22222,0 2px 0 #ffb703,0 3px 0 #fff,0 6px 1px rgba(255,255,255,.1),0 0 20px rgba(230,57,70,.4)!important}#streak-count{filter:drop-shadow(0 0 8px #ffb703);animation:twinkle 1.5s infinite ease-in-out}@keyframes twinkle{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.05);opacity:.8}}.btn-pulse{background:linear-gradient(45deg,#e63946,#2b9348)!important;color:#fff!important;border:none!important;box-shadow:0 0 15px rgba(43,147,72,.5)!important}.item-card{background:#f1faee!important;border-radius:15px!important}.selected-card{border-color:#ffb703!important;box-shadow:0 0 10px #ffb703}.sidebar{border-top:2px solid #e63946!important}.tab-btn.active{color:#e63946!important}.tab-btn.active::after{background:#2b9348!important}.v-control-btn{border-color:rgba(230,57,70,.3)!important}"
